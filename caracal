/*
|--------------------------------------------------------------------------
| ROUTE LIST
|--------------------------------------------------------------------------
*/
$console->add(new class extends Command {

    protected function configure(): void
    {
        $this
            ->setName('route:list')
            ->setDescription('Display all registered routes');
    }

    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        $app = Application::getInstance();

        $router = new \Caracal\Core\Router($app);

        $routes = $router->loadRoutes();

        if (!$routes) {
            $output->writeln('<comment>No routes registered</comment>');
            return Command::SUCCESS;
        }

        $table = new \Symfony\Component\Console\Helper\Table($output);

        $table->setHeaders([
            'Method',
            'Path',
            'Handler',
            'Name',
            'Middleware'
        ]);

        foreach ($routes as $route) {

            $middleware = !empty($route['middleware'])
                ? implode(',', $route['middleware'])
                : '-';

            $table->addRow([
                $route['method'] ?? '',
                $route['path'] ?? '',
                $route['handler'] ?? '',
                $route['name'] ?? '-',
                $middleware
            ]);
        }

        $table->render();

        return Command::SUCCESS;
    }
});

/*
|--------------------------------------------------------------------------
| Helper: Validate Name
|--------------------------------------------------------------------------
*/
function caracalName(string $name): string
{
    if (!preg_match('/^[A-Za-z0-9]+$/', $name)) {
        throw new Exception("Invalid name '{$name}'. Only letters and numbers allowed.");
    }

    return ucfirst($name);
}

/*
|--------------------------------------------------------------------------
| Helper: Module Path
|--------------------------------------------------------------------------
*/
function modulePath(string $module, string $path = ''): string
{
    $base = __DIR__ . "/app/Modules/{$module}";
    return $path ? "{$base}/{$path}" : $base;
}

/*
|--------------------------------------------------------------------------
| Helper: Write File
|--------------------------------------------------------------------------
*/
function writeFile(string $file, string $content): void
{
    $dir = dirname($file);

    if (!is_dir($dir)) {
        mkdir($dir,0755,true);
    }

    if (!file_exists($file)) {
        file_put_contents($file,$content);
    }
}

/*
|--------------------------------------------------------------------------
| MAKE CONTROLLER
|--------------------------------------------------------------------------
*/
$console->add(new class extends Command {

    protected function configure(): void {
        $this->setName('make:controller')
            ->setDescription('Generate module controller')
            ->addArgument('module', InputArgument::REQUIRED)
            ->addArgument('name', InputArgument::REQUIRED);
    }

    protected function execute(InputInterface $input, OutputInterface $output): int {

        try {

            $module = caracalName($input->getArgument('module'));
            $name   = caracalName($input->getArgument('name'));

            $file = modulePath($module,"Controllers/{$name}.php");

            $code = <<<PHP
<?php

namespace App\Modules\\{$module}\Controllers;

use Caracal\Core\Controller;

class {$name} extends Controller
{
    public function index(): string
    {
        return \$this->view(
            '{$module}/Views/'.strtolower('{$name}').'.view.php',
            ['title' => '{$name}']
        );
    }
}
PHP;

            writeFile($file,$code);

            $output->writeln("<info>Controller {$name} created</info>");
            return Command::SUCCESS;

        } catch(Exception $e) {

            $output->writeln("<error>{$e->getMessage()}</error>");
            return Command::FAILURE;

        }
    }
});

