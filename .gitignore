# PHP / Composer
/vendor/
composer.lock

# Environment
.env
.env.local
.env.*.php

# IDE / OS
.idea/
.vscode/
*.swp
*.DS_Store
Thumbs.db

# Logs
/storage/logs/*.log
/storage/logs/*.log.*

# Cache
/storage/cache/*
!storage/cache/.gitignore

# Sessions
/storage/sessions/*
!storage/sessions/.gitignore

# Uploads (private)
storage/uploads/*
!storage/uploads/.gitignore

# Public uploads (if user content should not be in repo)
public/uploads/*
!public/uploads/.gitignore

# Node / Assets (optional if using npm / yarn)
node_modules/
npm-debug.log
yarn-error.log

# Generated files
*.cache
*.tmp